generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                 Int      @id @default(autoincrement())
  shopify_id         String   @unique
  title              String
  status             String
  vendor             String?
  price              String
  inventory_quantity Int      @default(0)
  image_url          String?
  synced_at          DateTime @default(now())
}